# Copy to ~/.config/sipclient-release.env (chmod 600) and fill in.
# bin/make_release.sh sources this file automatically.

# Apple ID for notarytool. Use the email of your developer account.
APPLE_ID="you@example.com"

# 10-character Developer Team ID (matches DEVELOPMENT_TEAM in Xcode).
APPLE_TEAM_ID="WDCGJTU726"

# App-specific password generated at appleid.apple.com → Sign-In and
# Security → App-Specific Passwords. Never use your iCloud password.
APPLE_APP_SPECIFIC_PASSWORD="abcd-efgh-ijkl-mnop"

# File holding the EdDSA private key produced by Sparkle's
# generate_keys. Do NOT commit this to the repo.
SPARKLE_PRIVATE_KEY_PATH="$HOME/.config/sipclient-sparkle.key"

# `security find-identity -v -p codesigning` to list yours. Must be a
# "Developer ID Application" identity (NOT "Apple Development").
SIGNING_IDENTITY="Developer ID Application: Your Name (WDCGJTU726)"
